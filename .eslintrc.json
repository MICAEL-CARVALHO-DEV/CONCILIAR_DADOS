{
  "env": {
    "browser": true,
    "es6": true,
    "es2021": true
  },
  "globals": {
    "SECFrontend": "readonly",
    "SEC_FRONTEND": "readonly",
    "globalThis": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-undef": "error",
    "eqeqeq": ["warn", "always", { "null": "ignore" }],
    "no-implicit-globals": "error",
    "no-var": "off",
    "semi": ["warn", "always"],
    "no-console": "warn"
  },
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "ignorePatterns": [
    "vendor/",
    ".cf-pages-dist/",
    "backend/"
  ],
  "overrides": [
    {
      "files": ["app.js"],
      "rules": {
        "no-implicit-globals": "off"
      }
    }
  ]
}
