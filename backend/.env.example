# Banco de dados
# Exemplo Supabase (SQLAlchemy + psycopg):
# DATABASE_URL=postgresql+psycopg://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=sqlite+pysqlite:///./test.db

# Ambiente
APP_ENV=development

# CORS (front oficial + locais)
CORS_ORIGINS=https://micael-carvalho-dev.github.io,https://conciliar-dados.pages.dev,https://homolog-cloudflare.conciliar-dados.pages.dev,http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5501,http://localhost:5501
# Opcional (recomendado para previews do Cloudflare Pages)
CORS_ALLOW_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?conciliar-dados\.pages\.dev$|^https://micael-carvalho-dev\.github\.io$|^http://(localhost|127\.0\.0\.1)(:\d+)?$

# Auth API
API_AUTH_ENABLED=true
ALLOW_SHARED_KEY_AUTH=false
API_SHARED_KEY=
JWT_SECRET_KEY=defina-um-segredo-forte-com-32-caracteres-ou-mais
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=12

# Google Identity (OAuth Sign-In)
GOOGLE_CLIENT_ID=
# Opcional (csv): permite mais de um client id durante migracao/homologacao.
# GOOGLE_CLIENT_IDS=1090925215709-otj49ouef21e8p0vr0nb97rkjfrt4mjc.apps.googleusercontent.com,905274978136-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=

# R07 backup / restore
# BACKUP_DATABASE_URL=postgresql://usuario:senha@host:porta/banco_operacional
# BACKUP_OUTPUT_ROOT=C:\Users\<USUARIO>\conciliar-backups\r07
# BACKUP_MIRROR_OUTPUT_ROOT=C:\Users\<USUARIO>\Google Drive\SEC_EMENDAS_BACKUP
# BACKUP_RESTORE_DATABASE_URL=postgresql://usuario:senha@host:porta/banco_restore
# Validacao local do R07 sem Docker Desktop:
# R07_VALIDATION_ADMIN_DATABASE_URL=postgresql://postgres:senha@127.0.0.1:5432/postgres

# Multi-AI Orchestrator
AI_ORCHESTRATOR_ENABLED=true
AI_ORCHESTRATOR_TIMEOUT_SECONDS=45

# Reis
OPENAI_API_KEY=
OPENAI_MODEL_CODEX=gpt-5.1-codex
GEMINI_API_KEY=
GEMINI_MODEL_PRO=gemini-2.5-pro

# Revisores / apoio
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_CLAUDE=claude-3-5-sonnet-latest
GROQ_API_KEY=
GROQ_MODEL_FREE=llama-3.3-70b-versatile
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_MODEL_FREE=@cf/meta/llama-3.1-8b-instruct

# Fallback local
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_FREE=llama3.2:3b
