#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
check_script="$repo_root/scripts/check_higiene_organizacao.ps1"

if [ ! -f "$check_script" ]; then
  echo "[pre-commit] ERRO: script nao encontrado em $check_script"
  exit 1
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$check_script" -RepoRoot "$repo_root"
  exit $?
fi

if command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$check_script" -RepoRoot "$repo_root"
  exit $?
fi

echo "[pre-commit] ERRO: nem 'pwsh' nem 'powershell' foram encontrados no PATH."
exit 1
